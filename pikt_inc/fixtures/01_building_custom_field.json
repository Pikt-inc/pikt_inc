  },
  {
    "doctype": "Custom Field",
    "dt": "Building",
    "name": "Building-preferred_service_start_time",
    "fieldname": "preferred_service_start_time",
    "label": "Preferred Service Start Time",
    "fieldtype": "Time",
    "insert_after": "service_frequency"
