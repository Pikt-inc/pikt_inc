    "fieldname": "service_days",
    "label": "Preferred Service Days (Legacy)",
    "fieldtype": "Data",
    "insert_after": "unavailable_service_days",
    "description": "Legacy exact-day service pattern retained temporarily for migration compatibility.",
    "hidden": 1
  },
  {
    "doctype": "Custom Field",
    "dt": "Building",
    "name": "Building-service_frequency",
    "fieldname": "service_frequency",
    "label": "Preferred Service Frequency",
    "fieldtype": "Int",
    "insert_after": "service_days",
