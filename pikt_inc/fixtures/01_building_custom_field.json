[
  {
    "doctype": "Custom Field",
    "dt": "Building",
    "name": "Building-supervisor_user",
    "fieldname": "supervisor_user",
    "label": "Supervisor User",
    "fieldtype": "Link",
    "options": "User",
    "insert_after": "site_supervisor_phone",
    "description": "Primary supervisor user to receive dispatch escalation alerts."
  },
  {
    "doctype": "Custom Field",
    "dt": "Building",
    "name": "Building-access_details_confirmed",
    "fieldname": "access_details_confirmed",
