    "fieldtype": "Check",
    "insert_after": "first_service_notes"
  },
  {
    "doctype": "Custom Field",
    "dt": "Building",
    "name": "Building-access_details_completed_on",
    "fieldname": "access_details_completed_on",
    "label": "Access Details Completed On",
    "fieldtype": "Datetime",
    "insert_after": "access_details_confirmed",
    "read_only": 1
  },
  {
    "doctype": "Custom Field",
    "dt": "Building",
    "name": "Building-custom_service_agreement",
    "fieldname": "custom_service_agreement",
    "label": "Service Agreement",
    "fieldtype": "Link",
    "options": "Service Agreement",
    "insert_after": "access_details_completed_on",
    "read_only": 1
  },
  {
    "doctype": "Custom Field",
    "dt": "Building",
    "name": "Building-custom_service_agreement_addendum",
