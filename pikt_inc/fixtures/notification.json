    "message": "{% set accepted_link = frappe.utils.get_url('/quote-accepted?quote=' ~ doc.name ~ '&token=' ~ doc.custom_accept_token) %}\n<div style=\"font-family:Arial,sans-serif;font-size:14px;line-height:1.6;color:#222;max-width:640px;\">\n  <p>Hello,</p>\n  <p>Your quotation is ready. Use the secure button below to accept the quote, sign the service agreement, set up billing, and confirm site access in one portal.</p>\n  <div style=\"border:1px solid #e5e5e5;border-radius:8px;padding:18px 20px;margin:20px 0;background:#fafafa;\">\n    <p style=\"margin:0 0 8px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:#666;\">Quotation</p>\n    <p style=\"margin:0;font-size:22px;font-weight:700;color:#111;\">{{ doc.name }}</p>\n    <p style=\"margin:10px 0 0;color:#444;\">Total: <strong>{{ frappe.utils.fmt_money(doc.rounded_total or doc.grand_total or 0, currency=doc.currency) }}</strong></p>\n    {% if doc.valid_till %}<p style=\"margin:6px 0 0;color:#444;\">Valid Through: <strong>{{ doc.valid_till }}</strong></p>{% endif %}\n  </div>\n  <p style=\"margin:26px 0;\">\n    <a href=\"{{ accepted_link }}\" style=\"display:inline-block;background:#171717;color:#fff;text-decoration:none;padding:12px 24px;border-radius:6px;font-weight:700;\">Accept Quote and Complete Setup</a>\n  </p>\n  <p>If you need anything adjusted before moving forward, reply to this email and our team will help.</p>\n</div>",
